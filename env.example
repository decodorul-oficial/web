# GraphQL
NEXT_PUBLIC_GRAPHQL_ENDPOINT=/api/graphql
# Server-to-server direct (sitemap, proxy upstream) — același host ca API-ul Vercel
EXTERNAL_GRAPHQL_ENDPOINT=https://decodorul-oficial-api.vercel.app/graphql
NEXT_PUBLIC_BASE_URL=https://www.decodoruloficial.ro

# Internal API key (server only) — OBLIGATORIU pe Vercel web, aceeași valoare ca pe API
INTERNAL_API_KEY=your-internal-api-key-min-32-chars

# Feature flags
SIGNUP_ENABLED=true
NEXT_PUBLIC_SIGNUP_ENABLED=true
PAYMENTS_ENABLED=false
NEXT_PUBLIC_PAYMENTS_ENABLED=false

# Stripe (server only unless noted)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:3000/profile?checkout=success
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:3000/profile
STRIPE_CHECKOUT_LOCALE=ro
NEXT_PUBLIC_STRIPE_CUSTOMER_PORTAL_SOURCE=api
